node_modules/
.env
.env.*
!.env.example
.DS_Store
tokens-raw/

# IDE
.vscode/
.idea/

# Build output (default ignore; specific allow-lists below)
dist/
build/
*.log
storybook-static/
.turbo/
coverage/

# tokens/dist/ is vendored on purpose — consumers copy from there
!tokens/dist/
# packages/tokens/dist/ is also vendored — same reason
!packages/tokens/dist/

# packages/react built dist is NOT vendored; consumers import the package
# (left as default-ignored above)

# Playwright
playwright-report/
test-results/
# Non-Linux visual snapshots — only the Linux baseline is committed
tests/visual/__snapshots__/**/*-darwin.png
tests/visual/__snapshots__/**/*-win32.png
