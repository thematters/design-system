node_modules/
.env
.env.*
!.env.example
.DS_Store
tokens-raw/
brand/sources/figma/**/cache/
# Bulk PNG extraction outputs (1088 frames × ~1MB) — keep manifest, ignore raster
brand/sources/figma/cc-branding/exports/all-frames/*/
!brand/sources/figma/cc-branding/exports/all-frames/manifest.json

# IDE
.vscode/
.idea/

# Build output (default ignore; specific allow-lists below)
dist/
build/
*.log
storybook-static/
.turbo/
coverage/

# tokens/dist/ is vendored on purpose — consumers copy from there
!tokens/dist/
# packages/tokens/dist/ is also vendored — same reason
!packages/tokens/dist/

# packages/react built dist is NOT vendored; consumers import the package
# (left as default-ignored above)

# Playwright
playwright-report/
test-results/

# Template renderer outputs (smoke-tested locally; commit-on-demand)
templates/.example-output/
templates/.generated/
templates/**/.rendered.html
# Non-Linux visual snapshots — only the Linux baseline is committed
tests/visual/__snapshots__/**/*-darwin.png
tests/visual/__snapshots__/**/*-win32.png
