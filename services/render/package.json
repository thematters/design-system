{
  "name": "@matters/design-system-render-service",
  "version": "0.0.0",
  "private": true,
  "description": "Matters Design System — HTTP wrapper around the Phase 6 Playwright template renderer. Skeleton: POST JSON, get a PNG.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thematters/design-system.git",
    "directory": "services/render"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./render": {
      "types": "./dist/render.d.mts",
      "import": "./dist/render.mjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('node:fs');fs.cpSync('src/render.mjs','dist/render.mjs');fs.cpSync('src/render.d.mts','dist/render.d.mts')\"",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@playwright/test": "1.48.2",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
