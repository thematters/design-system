---
import type { ActivityLandingContent } from "../content/page";

interface Props {
  faq: NonNullable<ActivityLandingContent["faq"]>;
}

const { faq } = Astro.props;
---

<section class="board rules" aria-labelledby="rules-title">
  <p class="eyebrow">{faq.eyebrow}</p>
  <h2 class="rules__title" id="rules-title">{faq.title}</h2>

  <div class="rules__list">
    {
      faq.items.map((item, i) => (
        <details class="rules__item" open={i === 0}>
          <summary>
            <span>{item.question}</span>
            <span class="rules__chev" aria-hidden="true">+</span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .rules__title {
    font-family: var(--font-reading);
    font-size: clamp(22px, 3.2vw, 28px);
    font-weight: 700;
    margin: 0 0 var(--space-sp32) 0;
    color: var(--ink);
  }

  .rules__list {
    display: flex;
    flex-direction: column;
  }

  .rules__item {
    border-top: 1px solid var(--line);
    padding: var(--space-sp16) 0;
  }

  .rules__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .rules__item summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sp16);
    font-weight: 600;
    color: var(--ink);
  }

  .rules__item summary::-webkit-details-marker {
    display: none;
  }

  .rules__chev {
    color: var(--brand-purple);
    font-weight: 400;
    font-size: 24px;
    transition: transform 0.18s ease;
  }

  .rules__item[open] .rules__chev {
    transform: rotate(45deg);
  }

  .rules__item p {
    margin: var(--space-sp12) 0 0 0;
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.8;
  }
</style>
