{
  "name": "@matters/design-system-react",
  "version": "0.2.0",
  "description": "Matters Design System — React component library (Phase 1: Button).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thematters/design-system.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.module.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "figma:connect:parse": "figma connect parse",
    "figma:connect:publish": "figma connect publish",
    "figma:connect:unpublish": "figma connect unpublish"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {
    "@matters/design-system-tokens": "workspace:*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@figma/code-connect": "^1.3.0",
    "happy-dom": "^15.0.0",
    "jest-axe": "^9.0.0",
    "@types/jest-axe": "^3.5.9",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
