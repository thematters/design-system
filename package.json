{
  "name": "@matters/design-system-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Matters Design System — monorepo root. Tokens, React components, Storybook docs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thematters/design-system.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build:tokens": "pnpm --filter @matters/design-system-tokens build",
    "build:react": "pnpm --filter @matters/design-system-react build",
    "build": "pnpm -r build",
    "dev:storybook": "pnpm --filter @matters/design-system-storybook dev",
    "build:storybook": "pnpm --filter @matters/design-system-storybook build",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,css}\"",
    "typecheck": "pnpm -r typecheck",
    "scaffold:component": "node scripts/scaffold-component.mjs",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm -r --filter './packages/*' build && changeset publish",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.9",
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
